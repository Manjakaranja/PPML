# MLproject

name: ppml-flight-delay

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 1500}
      learning_rate: {type: float, default: 0.04}
      max_depth: {type: int, default: 9}
      test_size: {type: float, default: 0.2}
      
    command: "python train.py --n-estimators {n_estimators} --learning-rate {learning_rate} --max-depth {max_depth} --test-size {test_size}"
